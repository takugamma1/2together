{{ '2gether-custom.css' | asset_url | stylesheet_tag }}
{{ '2gether-collection.css' | asset_url | stylesheet_tag }}
{% # theme-check-disable RemoteAsset %}
<link href="https://api.fontshare.com/v2/css?f[]=technor@400,500,600,700&f[]=general-sans@400,500,600,700&f[]=boska@400,500,700&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<script>document.body.classList.add('tg-collection-active');</script>

{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign products_count = collection.products_count
-%}

<!-- Top Navigation -->
<nav class="tg-coll-nav">
  <a href="/" class="tg-coll-nav-brand">2GETHER</a>
  <ul class="tg-coll-nav-links">
    <li><a href="/collections/all">Shop</a></li>
    <li><a href="/collections">Collections</a></li>
    <li><a href="/pages/about">About</a></li>
    <li><a href="/pages/contact">Contact</a></li>
  </ul>
  <div class="tg-coll-nav-icons">
    <a href="/search" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    </a>
    <a href="/account" aria-label="Account">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </a>
    <a href="/cart" aria-label="Cart">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
    </a>
  </div>
</nav>

<!-- Mobile filter overlay -->
<div class="tg-filter-overlay" id="tg-filter-overlay" onclick="document.getElementById('tg-filter-sidebar').classList.remove('open');this.classList.remove('open');"></div>

<!-- Mobile filter toggle -->
<button class="tg-filter-toggle" onclick="document.getElementById('tg-filter-sidebar').classList.toggle('open');document.getElementById('tg-filter-overlay').classList.toggle('open');">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 21v-7m0-4V3m8 18v-9m0-4V3m8 18v-5m0-4V3M1 14h6M9 8h6M17 16h6"/></svg>
  Filters
</button>

<div class="tg-collection-page">
  <!-- ═══ LEFT SIDEBAR: Filters ═══ -->
  <aside class="tg-coll-sidebar" id="tg-filter-sidebar">
    <button class="tg-filter-close" onclick="document.getElementById('tg-filter-sidebar').classList.remove('open');document.getElementById('tg-filter-overlay').classList.remove('open');">✕</button>

    {% for filter in collection.filters %}
      <div class="tg-filter-group">
        <div class="tg-filter-title">{{ filter.label }}</div>

        {% case filter.type %}
          {% when 'list' %}
            {% for value in filter.values %}
              <label class="tg-filter-option">
                <input
                  type="checkbox"
                  name="{{ value.param_name }}"
                  value="{{ value.value }}"
                  {% if value.active %}checked{% endif %}
                  onchange="tgApplyFilters()"
                >
                <span class="tg-filter-check"></span>
                <span class="tg-filter-label">{{ value.label }}</span>
                <span class="tg-filter-count">{{ value.count }}</span>
              </label>
            {% endfor %}

          {% when 'price_range' %}
            <div class="tg-filter-price-inputs">
              <input
                type="number"
                class="tg-filter-price-input"
                name="{{ filter.min_value.param_name }}"
                id="tg-price-min"
                value="{{ filter.min_value.value | default: 0 | money_without_currency | replace: ',', '' }}"
                min="0"
                max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                placeholder="{{ 0 | money }}"
              >
              <span class="tg-filter-price-sep">—</span>
              <input
                type="number"
                class="tg-filter-price-input"
                name="{{ filter.max_value.param_name }}"
                id="tg-price-max"
                value="{{ filter.max_value.value | default: filter.range_max | money_without_currency | replace: ',', '' }}"
                min="0"
                max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                placeholder="{{ filter.range_max | money }}"
              >
            </div>

        {% endcase %}
      </div>
    {% endfor %}

    {% if collection.filters.size > 0 %}
      <button class="tg-filter-apply" onclick="tgApplyFilters()">Apply Filters</button>
    {% endif %}
  </aside>

  <!-- ═══ MAIN CONTENT ═══ -->
  <div class="tg-coll-main">

    <!-- Hero Banner -->
    <div class="tg-coll-hero">
      <div class="tg-coll-hero-left">
        <h1 class="tg-coll-hero-title">
          {% if section.settings.hero_title != blank %}
            {{ section.settings.hero_title }}
          {% else %}
            THE {{ collection.title | upcase }}<span>.</span>
          {% endif %}
        </h1>
        {% if collection.description != blank %}
          <p class="tg-coll-hero-desc">{{ collection.description | strip_html }}</p>
        {% endif %}
        <div class="tg-coll-hero-actions">
          <a href="#tg-products-grid" class="tg-coll-browse-btn">Browse &darr;</a>
        </div>
      </div>
      <div class="tg-coll-hero-right">
        <div class="tg-coll-sort">
          <label for="tg-sort-select">Sort:</label>
          <select id="tg-sort-select" onchange="tgApplySort(this.value)">
            <option value="manual" {% if sort_by == 'manual' %}selected{% endif %}>Featured</option>
            <option value="best-selling" {% if sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
            <option value="title-ascending" {% if sort_by == 'title-ascending' %}selected{% endif %}>A–Z</option>
            <option value="title-descending" {% if sort_by == 'title-descending' %}selected{% endif %}>Z–A</option>
            <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>Price: Low → High</option>
            <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>Price: High → Low</option>
            <option value="created-ascending" {% if sort_by == 'created-ascending' %}selected{% endif %}>Oldest</option>
            <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
          </select>
        </div>
        <div class="tg-coll-count">{{ products_count }} {{ products_count | pluralize: 'Machine', 'Machines' }}</div>
      </div>
    </div>

    <!-- Product Grid -->
    <div class="tg-coll-grid" id="tg-products-grid">
      {% paginate collection.products by section.settings.products_per_page %}
        {% for product in collection.products %}
          <div class="tg-coll-card" data-product-id="{{ product.id }}">
            <!-- Link wrapping image -->
            <a href="{{ product.url }}" class="tg-coll-card-image">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(max-width: 768px) 100vw, 50vw' }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}

              {% if product.compare_at_price > product.price %}
                <span class="tg-coll-badge tg-coll-badge--sale">Sale</span>
              {% elsif product.tags contains 'new' %}
                <span class="tg-coll-badge tg-coll-badge--new">New</span>
              {% endif %}

              {% unless product.available %}
                <span class="tg-coll-badge tg-coll-badge--sold-out">Sold Out</span>
              {% endunless %}
            </a>

            <!-- Card info -->
            <div class="tg-coll-card-info">
              <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">
                <div class="tg-coll-card-name">{{ product.title }}</div>
              </a>
              <div class="tg-coll-card-price">
                {{ product.price | money }}
                {% if product.compare_at_price > product.price %}
                  <span class="tg-coll-card-price-compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>

            <!-- Color swatches -->
            {% assign color_option = nil %}
            {% for option in product.options_with_values %}
              {% assign opt_lower = option.name | downcase %}
              {% if opt_lower == 'color' or opt_lower == 'colour' %}
                {% assign color_option = option %}
              {% endif %}
            {% endfor %}

            {% if color_option %}
              <div class="tg-coll-card-swatches">
                {% for value in color_option.values %}
                  <span
                    class="tg-coll-card-swatch"
                    style="background-color: {{ value | handleize }};"
                    title="{{ value }}"
                  ></span>
                {% endfor %}
              </div>
            {% endif %}

            <!-- Quick Add to Cart -->
            {%- form 'product', product, class: 'tg-coll-card-form' -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button
                type="submit"
                class="tg-coll-card-add"
                {% unless product.available %}disabled{% endunless %}
              >
                {% if product.available %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                  Add to Cart
                {% else %}
                  Sold Out
                {% endif %}
              </button>
            {%- endform -%}
          </div>
        {% endfor %}

        <!-- Pagination -->
        {% if paginate.pages > 1 %}
          <div class="tg-coll-pagination" style="grid-column: 1 / -1;">
            <div class="tg-coll-showing">
              Showing <strong>{{ paginate.current_offset | plus: 1 }}–{{ paginate.current_offset | plus: paginate.page_size | at_most: products_count }}</strong> of <strong>{{ products_count }}</strong> high-performance machines
            </div>

            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" class="tg-coll-load-more">Load More Machines</a>
            {% endif %}

            <div class="tg-coll-pages">
              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}" aria-label="Previous">&larr;</a>
              {% endif %}
              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {% else %}
                  <span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>
                {% endif %}
              {% endfor %}
              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" aria-label="Next">&rarr;</a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endpaginate %}
    </div>

    <!-- Footer -->
    <div class="tg-coll-footer">
      <div class="tg-coll-footer-brand">2GETHER</div>
      <div class="tg-coll-footer-links">
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/shipping-policy">Shipping</a>
        <a href="/policies/refund-policy">Returns</a>
        <a href="/pages/contact">Contact</a>
      </div>
    </div>
  </div>
</div>

<script>
  // Sort
  function tgApplySort(value) {
    var url = new URL(window.location);
    url.searchParams.set('sort_by', value);
    window.location = url.toString();
  }

  // Filter application
  function tgApplyFilters() {
    var url = new URL(window.location.pathname, window.location.origin);

    // Preserve sort
    var sort = new URL(window.location).searchParams.get('sort_by');
    if (sort) url.searchParams.set('sort_by', sort);

    // Collect checked filters
    document.querySelectorAll('.tg-filter-option input:checked').forEach(function(input) {
      url.searchParams.append(input.name, input.value);
    });

    // Collect price range
    var minInput = document.getElementById('tg-price-min');
    var maxInput = document.getElementById('tg-price-max');
    if (minInput && minInput.value) {
      url.searchParams.set(minInput.name, (parseFloat(minInput.value) * 100).toString());
    }
    if (maxInput && maxInput.value) {
      url.searchParams.set(maxInput.name, (parseFloat(maxInput.value) * 100).toString());
    }

    window.location = url.toString();
  }

  // Quick add to cart via AJAX
  document.querySelectorAll('.tg-coll-card-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = form.querySelector('.tg-coll-card-add');
      var origText = btn.innerHTML;
      btn.innerHTML = 'Adding...';
      btn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form)).toString()
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg> Added!';
        setTimeout(function() {
          btn.innerHTML = origText;
          btn.disabled = false;
        }, 1500);
      })
      .catch(function() {
        btn.innerHTML = origText;
        btn.disabled = false;
      });
    });
  });
</script>

{% schema %}
{
  "name": "2Gether Collection",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title override",
      "info": "Leave blank to auto-generate from collection title"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 8
    }
  ],
  "blocks": [],
  "templates": ["collection"]
}
{% endschema %}
