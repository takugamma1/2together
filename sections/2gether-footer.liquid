<footer class="tg-footer tg-section">
  {%- comment -%}Row 1: Newsletter{%- endcomment -%}
  <div class="tg-footer-newsletter">
    <div class="tg-footer-newsletter-bg">
      {% if section.settings.newsletter_bg_image != blank %}
        {{ section.settings.newsletter_bg_image | image_url: width: 1920 | image_tag: loading: 'lazy', sizes: '100vw' }}
      {% endif %}
    </div>
    <div class="tg-footer-newsletter-info">
      <span class="tg-footer-newsletter-title">{{ section.settings.newsletter_title }}</span>
      <p class="tg-footer-newsletter-text">{{ section.settings.newsletter_text }}</p>
    </div>
    {% form 'customer', class: 'tg-footer-newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" class="tg-footer-newsletter-input" placeholder="{{ section.settings.newsletter_placeholder }}" required>
      <button type="submit" class="tg-footer-newsletter-btn">{{ section.settings.newsletter_button }}</button>
    {% endform %}
  </div>

  {%- comment -%}Row 2: Map + Links{%- endcomment -%}
  <div class="tg-footer-middle">
    <div class="tg-footer-map">
      {% if section.settings.map_embed != blank %}
        <iframe class="tg-footer-map-frame" src="{{ section.settings.map_embed }}" allowfullscreen="" loading="lazy"></iframe>
      {% endif %}
      <div class="tg-footer-map-address">
        <strong>{{ section.settings.store_name }}</strong><br>
        {{ section.settings.address }}
      </div>
    </div>
    <div class="tg-footer-links-grid">
      {% for block in section.blocks %}
        {% if block.type == 'link_column' %}
          <div {{ block.shopify_attributes }}>
            <div class="tg-footer-heading">{{ block.settings.heading }}</div>
            {% if block.settings.menu != blank %}
              <ul class="tg-footer-links">
                {% for link in block.settings.menu.links %}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {%- comment -%}Row 3: Jumbo brand{%- endcomment -%}
  <div class="tg-footer-brand-strip">
    <div class="tg-footer-jumbo">{{ section.settings.jumbo_text }}</div>
    <div class="tg-footer-jumbo-sub">{{ section.settings.jumbo_subtitle }}</div>
  </div>

  {%- comment -%}Bottom bar{%- endcomment -%}
  <div class="tg-footer-bottom">
    <span class="tg-footer-copy">&copy; {{ 'now' | date: '%Y' }} {{ section.settings.store_name }}</span>
    <div class="tg-footer-locale">
      {% for block in section.blocks %}
        {% if block.type == 'locale_link' %}
          <a href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</footer>

<script src="{{ '2gether-custom.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "2Gether Footer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "image_picker",
      "id": "newsletter_bg_image",
      "label": "Newsletter background image"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter title",
      "default": "Lorem ipsum dolor sit amet"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Map & Address"
    },
    {
      "type": "text",
      "id": "map_embed",
      "label": "Google Maps embed URL"
    },
    {
      "type": "text",
      "id": "store_name",
      "label": "Store name",
      "default": "2GETHER BIKES"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "Варна, България\n+359 XX XXX XXXX"
    },
    {
      "type": "header",
      "content": "Brand Strip"
    },
    {
      "type": "text",
      "id": "jumbo_text",
      "label": "Jumbo text",
      "default": "2GETHER BIKES"
    },
    {
      "type": "text",
      "id": "jumbo_subtitle",
      "label": "Jumbo subtitle",
      "default": "Варна, България"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "locale_link",
      "name": "Locale Link",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "BG"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "2Gether Footer",
      "blocks": [
        { "type": "link_column", "settings": { "heading": "Магазин" } },
        { "type": "link_column", "settings": { "heading": "Компания" } },
        { "type": "locale_link", "settings": { "label": "BG" } },
        { "type": "locale_link", "settings": { "label": "EN" } }
      ]
    }
  ]
}
{% endschema %}
