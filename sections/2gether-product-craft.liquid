<section class="tg-pdp-craft tg-section">
  <div class="tg-pdp-craft-inner">
    <div class="tg-pdp-craft-content">
      <span class="tg-label">{{ section.settings.label_text }}</span>
      <h2 class="tg-pdp-craft-title tg-reveal">{{ section.settings.heading }}</h2>
      <p class="tg-pdp-craft-text tg-reveal">{{ section.settings.description }}</p>

      {% if section.blocks.size > 0 %}
        <div class="tg-pdp-craft-stats">
          {% for block in section.blocks %}
            {% if block.type == 'stat' %}
              <div class="tg-pdp-craft-stat" {{ block.shopify_attributes }}>
                <p class="tg-pdp-craft-stat-value">{{ block.settings.value }}</p>
                <p class="tg-pdp-craft-stat-label">{{ block.settings.label }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="tg-pdp-craft-media tg-reveal">
      <div class="tg-pdp-craft-image">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag }}
        {% endif %}
      </div>
      {% if section.settings.quote_text != blank %}
        <div class="tg-pdp-craft-quote">
          <p>"{{ section.settings.quote_text }}"</p>
          {% if section.settings.quote_author != blank %}
            <cite>— {{ section.settings.quote_author }}</cite>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "2Gether Craftsmanship",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label_text",
      "label": "Label",
      "default": "The Process"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Pure<br>Fiber.</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Each APEX frame is hand-laid over 72 hours, using ultra-high-modulus Toray carbon. This creates a frame that is vertically compliant yet laterally stiff, ensuring every watt you produce is converted into forward momentum."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Feature image"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote text",
      "default": "The responsiveness is unparalleled. It feels like the bike anticipates your next move."
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Quote author",
      "default": "Martin V., Lead Engineer"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "0.4mm"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Wall Precision"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "2Gether Craftsmanship",
      "blocks": [
        { "type": "stat", "settings": { "value": "0.4mm", "label": "Wall Precision" } },
        { "type": "stat", "settings": { "value": "1200g", "label": "Total System" } }
      ]
    }
  ]
}
{% endschema %}
