{{ '2gether-custom.css' | asset_url | stylesheet_tag }}
{{ '2gether-about.css' | asset_url | stylesheet_tag }}
{% # theme-check-disable RemoteAsset %}
<link href="https://api.fontshare.com/v2/css?f[]=technor@400,500,600,700&f[]=general-sans@400,500,600,700&f[]=boska@400,500,700&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<script>document.body.classList.add('tg-about-active');</script>

<div class="tg-about-page">

  <!-- ═══ Top Navigation ═══ -->
  <nav class="tg-about-nav">
    <a href="/" class="tg-about-nav-brand">2GETHER</a>
    <ul class="tg-about-nav-links">
      <li><a href="/collections/all">Shop</a></li>
      <li><a href="/collections">Collections</a></li>
      <li><a href="/pages/about">About</a></li>
      <li><a href="/pages/contact">Contact</a></li>
    </ul>
    <div class="tg-about-nav-icons">
      <a href="/search" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </a>
      <a href="/account" aria-label="Account">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="/cart" aria-label="Cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </a>
    </div>
  </nav>

  <!-- ═══ HERO ═══ -->
  <section class="tg-about-hero">
    <div class="tg-about-hero-bg">
      {% if section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 1920 | image_tag: loading: 'eager', sizes: '100vw' }}
      {% endif %}
    </div>
    <div class="tg-about-hero-content">
      <h1 class="tg-about-hero-title">
        {{ section.settings.hero_line1 | default: 'ENGINEERED' }}<br>
        {{ section.settings.hero_line2 | default: 'FOR THE' }}<br>
        <span>{{ section.settings.hero_line3 | default: 'NIGHT' }}</span>
      </h1>
      {% if section.settings.hero_subtitle != blank %}
        <p class="tg-about-hero-sub">{{ section.settings.hero_subtitle }}</p>
      {% endif %}
    </div>
  </section>

  <!-- ═══ THE VISION ═══ -->
  <section class="tg-about-vision">
    <div class="tg-about-vision-left">
      <div class="tg-about-vision-label">{{ section.settings.vision_label | default: 'The Vision' }}</div>
      {% if section.settings.vision_image != blank %}
        {{ section.settings.vision_image | image_url: width: 1000 | image_tag: loading: 'lazy', sizes: '(max-width: 1024px) 100vw, 55vw' }}
      {% else %}
        <div style="width:100%;height:100%;background:var(--tg-surface-raised);"></div>
      {% endif %}
    </div>
    <div class="tg-about-vision-right">
      <blockquote class="tg-about-vision-quote">
        {{ section.settings.vision_quote | default: 'We don&rsquo;t build bikes for <em>everyone</em>. We build them for those who see the road as a canvas and speed as a language.' }}
      </blockquote>
      <p class="tg-about-vision-body">
        {{ section.settings.vision_body | default: '2Gether was founded on a single conviction: that cycling at its highest level is an act of engineering art. Every frame, every component, every curve is a deliberate choice — optimized for riders who demand both performance and soul.' }}
      </p>
      {% if section.settings.vision_signature != blank %}
        <div class="tg-about-vision-sig">
          <span class="tg-about-vision-sig-line"></span>
          <span class="tg-about-vision-sig-name">{{ section.settings.vision_signature }}</span>
        </div>
      {% endif %}
    </div>
  </section>

  <!-- ═══ THE PROCESS ═══ -->
  <section class="tg-about-process">
    <div class="tg-about-process-label">{{ section.settings.process_label | default: 'The Process' }}</div>
    <div class="tg-about-process-grid">
      {% for block in section.blocks %}
        {% if block.type == 'process_step' %}
          <div class="tg-process-card" {{ block.shopify_attributes }}>
            <div class="tg-process-num">{{ block.settings.number | default: forloop.index | prepend: '00' | slice: -2, 2 }}</div>
            <div class="tg-process-title">{{ block.settings.title }}</div>
            <p class="tg-process-desc">{{ block.settings.description }}</p>
          </div>
        {% endif %}
      {% endfor %}

      {%- comment -%} Fallback defaults if no blocks configured {%- endcomment -%}
      {% assign process_count = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'process_step' %}
          {% assign process_count = process_count | plus: 1 %}
        {% endif %}
      {% endfor %}

      {% if process_count == 0 %}
        <div class="tg-process-card">
          <div class="tg-process-num">01</div>
          <div class="tg-process-title">Design</div>
          <p class="tg-process-desc">Every concept begins with aerodynamic simulation and computational geometry, refined through thousands of virtual wind tunnel iterations.</p>
        </div>
        <div class="tg-process-card">
          <div class="tg-process-num">02</div>
          <div class="tg-process-title">Fabrication</div>
          <p class="tg-process-desc">Aerospace-grade carbon fiber is hand-laid by master craftsmen, each layer precisely oriented for optimal stiffness-to-weight ratio.</p>
        </div>
        <div class="tg-process-card">
          <div class="tg-process-num">03</div>
          <div class="tg-process-title">Assembly</div>
          <p class="tg-process-desc">Final assembly is a 40-point inspection process. Every bike is individually tuned, test-ridden, and certified before shipping.</p>
        </div>
      {% endif %}
    </div>
  </section>

  <!-- ═══ IMAGE MOSAIC ═══ -->
  <div class="tg-about-mosaic">
    {% for block in section.blocks %}
      {% if block.type == 'mosaic_image' %}
        <div class="tg-mosaic-cell {% if block.settings.tall %}tg-mosaic-cell--tall{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {% else %}
            <div style="width:100%;height:100%;background:linear-gradient(160deg, var(--tg-ink-70), var(--tg-ink-90));"></div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}

    {%- comment -%} Fallback defaults {%- endcomment -%}
    {% assign mosaic_count = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'mosaic_image' %}
        {% assign mosaic_count = mosaic_count | plus: 1 %}
      {% endif %}
    {% endfor %}

    {% if mosaic_count == 0 %}
      <div class="tg-mosaic-cell tg-mosaic-cell--tall">
        <div style="width:100%;height:100%;background:linear-gradient(160deg, var(--tg-ink-70), var(--tg-ink-90));"></div>
      </div>
      <div class="tg-mosaic-cell">
        <div style="width:100%;height:100%;background:linear-gradient(140deg, var(--tg-surface-raised), var(--tg-ink-80));"></div>
      </div>
      <div class="tg-mosaic-cell">
        <div style="width:100%;height:100%;background:linear-gradient(200deg, var(--tg-ink-80), var(--tg-surface-raised));"></div>
      </div>
    {% endif %}
  </div>

  <!-- ═══ COMMUNITY / SUNDAY CLUB ═══ -->
  <section class="tg-about-community">
    <div class="tg-about-community-image">
      {% if section.settings.community_image != blank %}
        {{ section.settings.community_image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(max-width: 1024px) 100vw, 50vw' }}
      {% else %}
        <div style="width:100%;height:100%;background:var(--tg-surface-raised);"></div>
      {% endif %}
    </div>
    <div class="tg-about-community-content">
      <div class="tg-about-community-label">{{ section.settings.community_label | default: 'Community' }}</div>
      <h2 class="tg-about-community-title">{{ section.settings.community_title | default: 'SUNDAY CLUB' }}</h2>
      <p class="tg-about-community-desc">{{ section.settings.community_desc | default: 'Every Sunday, riders across Europe gather for group rides that push limits and forge connections. No pace groups — just shared passion for the road.' }}</p>
      {% if section.settings.community_cta_text != blank %}
        <a href="{{ section.settings.community_cta_link | default: '#' }}" class="tg-about-community-cta">
          {{ section.settings.community_cta_text }} &rarr;
        </a>
      {% endif %}
    </div>
  </section>

  <!-- ═══ CTA BANNER ═══ -->
  <section class="tg-about-cta">
    <h2 class="tg-about-cta-title">
      {{ section.settings.cta_title | default: 'READY FOR THE' }} <span>{{ section.settings.cta_title_accent | default: 'DARK?' }}</span>
    </h2>
    <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="tg-about-cta-btn">
      {{ section.settings.cta_btn_text | default: 'Explore Our Machines' }}
    </a>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <div class="tg-about-footer">
    <div class="tg-about-footer-brand">2GETHER</div>
    <div class="tg-about-footer-links">
      <a href="/policies/privacy-policy">Privacy Policy</a>
      <a href="/policies/shipping-policy">Shipping</a>
      <a href="/policies/refund-policy">Returns</a>
      <a href="/pages/contact">Contact</a>
    </div>
    <div class="tg-about-footer-copy">&copy; {{ 'now' | date: '%Y' }} 2Gether Bikes. All rights reserved.</div>
  </div>

</div>

{% schema %}
{
  "name": "2Gether About",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "hero_line1",
      "label": "Hero line 1",
      "default": "ENGINEERED"
    },
    {
      "type": "text",
      "id": "hero_line2",
      "label": "Hero line 2",
      "default": "FOR THE"
    },
    {
      "type": "text",
      "id": "hero_line3",
      "label": "Hero line 3 (accent color)",
      "default": "NIGHT"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero subtitle"
    },
    {
      "type": "header",
      "content": "The Vision"
    },
    {
      "type": "text",
      "id": "vision_label",
      "label": "Section label",
      "default": "The Vision"
    },
    {
      "type": "image_picker",
      "id": "vision_image",
      "label": "Vision image"
    },
    {
      "type": "html",
      "id": "vision_quote",
      "label": "Vision quote (use <em> for accent)"
    },
    {
      "type": "textarea",
      "id": "vision_body",
      "label": "Vision body text"
    },
    {
      "type": "text",
      "id": "vision_signature",
      "label": "Signature name",
      "default": "Founders, 2Gether"
    },
    {
      "type": "header",
      "content": "The Process"
    },
    {
      "type": "text",
      "id": "process_label",
      "label": "Section label",
      "default": "The Process"
    },
    {
      "type": "header",
      "content": "Community"
    },
    {
      "type": "image_picker",
      "id": "community_image",
      "label": "Community image"
    },
    {
      "type": "text",
      "id": "community_label",
      "label": "Community label",
      "default": "Community"
    },
    {
      "type": "text",
      "id": "community_title",
      "label": "Community title",
      "default": "SUNDAY CLUB"
    },
    {
      "type": "textarea",
      "id": "community_desc",
      "label": "Community description"
    },
    {
      "type": "text",
      "id": "community_cta_text",
      "label": "Community CTA text",
      "default": "Join the Ride"
    },
    {
      "type": "url",
      "id": "community_cta_link",
      "label": "Community CTA link"
    },
    {
      "type": "header",
      "content": "CTA Banner"
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA title",
      "default": "READY FOR THE"
    },
    {
      "type": "text",
      "id": "cta_title_accent",
      "label": "CTA title accent",
      "default": "DARK?"
    },
    {
      "type": "text",
      "id": "cta_btn_text",
      "label": "CTA button text",
      "default": "Explore Our Machines"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "process_step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    },
    {
      "type": "mosaic_image",
      "name": "Mosaic Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "tall",
          "label": "Tall (spans two rows)",
          "default": false
        }
      ]
    }
  ],
  "templates": ["page"]
}
{% endschema %}
